void setFeedingTime(){ \\יצירת פונקציה חדשה
  char j=0; \\ קביעת משתנה  ששוה ל0
  feed = true; \\מסמנים את המשתנה לנכון
   int i=0; \\קביעת משתנה שווה ל0
      lcd.clear(); \\מנקה את הלוח של הLCD
      delay(400);\\לזמן של 4 מילי שניות
  lcd.setCursor(0,0); \\ מסמן את המקום ההתחלתי
  lcd.print("Set feeding Time");\\ כותב על הלוח את מה שבסוגריים
  
  while(1){ \\ לולאה שחוזרת על עצמה עד שפקודת BREAK

      key = customKeypad.getKey(); \\קביעת המשתנים בעזרת הלחצנים
     

  if(key!=NO_KEY){ \\אם לחצו עם הלוח מקשים
      lcd.setCursor(j,1); מסמנים את המקום ההתחלתי
      lcd.print(key);\\ פולט ללוח את מה שלחצנו
      r[i] = key-48; \\קביעת המשתנה לפי מה שלחצנו על הלוח ושם את המספר לפי קוד אסקי
      i++; \\מגדיל את המשתנה ב-1
      delay(500);\\לזמן של 5 מילי שניה
      j++; \\מגדיל את השתנה ב-1
    }
         if (j== 2) \\ אם המשתנה שווה ל2
          {
            lcd.print(':');\\זה פולט ללוח את מה שבסוגריים
            j++; \\מגדיל את  המשתנה ב-1
           }
  if (key == 'D'); \\אם המשתנה שווה למה שבסוגריים
  {
    key=0; \\ אז המשתנה שווה ל0

    break; \\ ויוצאים מהלולאה
    }
            if(key == '*')\\אם המשתנה שווה למה שבסוגריים 
         {
           break;\\void אז יוצאים מה
         }

  }
 
  }



